  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "@octokit/rest": "^21.0.0",
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.0",
    "@cloudflare/workers-types": "^4.20260414.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.0.0"
  }
}
